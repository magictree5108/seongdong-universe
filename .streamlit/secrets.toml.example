# 이 파일을 secrets.toml 로 복사하고 값을 채우세요.
# (secrets.toml 은 .gitignore 에 의해 커밋되지 않습니다)
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Streamlit Community Cloud 배포 시에는 앱 설정 > Secrets 에 아래 내용을 붙여넣으세요.

# AI 검색 (질의 확장 + 관련성 선별) — 없으면 어휘 일치 검색만 동작
ANTHROPIC_API_KEY = "sk-ant-..."

# 국가 법령 실시간 검색 (선택) — 법제처 국가법령정보센터 Open API 인증키.
# open.law.go.kr 에서 발급, 호출 IP 등록 필요.
LAW_OC = ""
